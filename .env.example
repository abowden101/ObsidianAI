# ObsidianAI Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# Required
XAI_API_KEY=xai-your-key-here

# Optional: PostgreSQL (Render / Supabase / RDS)
# DATABASE_URL=postgresql://user:password@host:5432/obsidianai

# Optional: AWS S3 report storage
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=obsidianai-reports
